# Cloudflare Pages edge config. Static files in static/ are copied verbatim
# to public/, so this lands at the root of the deployed site.
#
# Cache strategy follows CLAUDE.md:
#   - Hashed, content-addressable assets: 1 year, immutable
#   - HTML: must-revalidate, ETag drives 304s
#
# Font preload is deliberately NOT set here. CLAUDE.md forbids shipping
# font bytes on first paint; font-display: optional keeps Cascadia strictly
# progressive.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.avif
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, s-maxage=300, stale-while-revalidate=60

/
  Cache-Control: public, s-maxage=300, stale-while-revalidate=60
